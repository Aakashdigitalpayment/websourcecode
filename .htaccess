# Coop site — minimal Apache helpers (ignored on nginx)
# Keep this file small: do not block public assets.

<IfModule mod_rewrite.c>
    RewriteEngine On
    # Block direct HTTP access to secrets / private PHP sources
    RewriteRule ^includes/ - [F,L]
    RewriteRule (^|/)\.cred - [F,L]
    RewriteRule \.cred-master\.key$ - [F,L]
    # Crawlers expect /sitemap.xml and /robots.txt
    RewriteRule ^sitemap\.xml$ sitemap.php [L,QSA]
    RewriteRule ^robots\.txt$ robots.php [L,QSA]
</IfModule>
