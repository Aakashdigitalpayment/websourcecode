/**
 * कपी: cp includes/superadmin-config.local.php.example includes/superadmin-config.local.php
 *
 * ⚠️ यो `.local.php` Git मा जाँदैन (`*.local.php` gitignore)।
 *    प्रत्येक project/cPanel मा छुट्टै फाइल + छुट्टै पासवर्ड राख्नुहोस्।
 *    Example वा real password कहिल्यै commit नगर्नुहोस्।
 *
 * डिजाइन (जानीजानी plain text):
 *   SUPER_ADMIN_INITIAL_PASSWORD यहीं plain राख्नु सजिलो login/sync का लागि हो।
 *   Login ले DB मा hash बनाउँछ; पासवर्ड बदल्न यही फाइल edit + फेरि login।
 *   खाली ('') पारेपछि change-password / DB मार्फत मात्र।
 */
declare(strict_types=1);

define('SUPER_ADMIN_USERNAME', 'myadmin');
define('SUPER_ADMIN_DISPLAY_NAME', 'Super Admin');
